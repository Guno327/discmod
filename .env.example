# Required
DISCORD_TOKEN=
DISCORD_GUILD_ID=
DISCORD_PROPOSAL_CHANNEL_ID=
PACK_DIR=/srv/modpack
ANTHROPIC_API_KEY=    # required unless SOFT_CONFLICTS_ENABLED=false
MODRINTH_USER_AGENT=username/projectname/0.1.0 (contact@example.com)

# Optional
DB_PATH=          # default: ${PACK_DIR}/../bot.db
GIT_REMOTE=origin
GIT_BRANCH=dev
GIT_MAIN_BRANCH=main   # branch discmod-release merges into
GITHUB_TOKEN=          # required for discmod-release (repo scope)
BOT_GIT_NAME=discmod-bot
BOT_GIT_EMAIL=discmod@localhost
MIN_APPROVALS=1
BLOCK_ON_HARD_CONFLICTS=false
PR_ON_HARD_CONFLICTS=true
SOFT_CONFLICTS_ENABLED=true   # set to false to disable AI soft-conflict checks (no Anthropic key needed)
LLM_MODEL=claude-haiku-4-5-20251001
DISCORD_ADMIN_ROLE_ID=
LOG_LEVEL=INFO
